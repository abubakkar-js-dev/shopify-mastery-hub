rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        (request.auth.token.email != null && request.auth.token.email.lower() == 'mdabubakkars182@gmail.com')
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // ✅ User Rules - FIXED
           match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      
      // ✅ FIX 1: Allow admins to delete user documents
      allow delete: if isAdmin();
      
      // ✅ FIX 2: Let admins bypass field restrictions (so they can update isAdmin, role, etc.)
      allow update: if isAdmin() || (
        isOwner(userId) && isValidUser(request.resource.data) && (
          request.resource.data.diff(resource.data).affectedKeys().hasAny([
            'completedLessons', 'personalizedPath', 'lastActive', 
            'displayName', 'completedVideos', 'completedTasks'
          ])
        )
      );

      function isValidUser(data) {
        return data.uid == request.auth.uid 
          && data.email is string
          && (data.get('completedLessons', []) is list)
          && (data.get('completedLessons', []).size() <= 1000);
      }
    }

    // ✅ Admin Rules - FIXED: Allow admins to promote/demote ANY user
    match /admins/{adminId} {
      allow get: if isSignedIn();
      // ✅ FIX: Allow any admin to create admin docs for any user (not just themselves)
      allow create: if isAdmin();
      allow list, update, delete: if isAdmin();
    }

    // Module Rules
    match /modules/{moduleId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
      
      match /lessons/{lessonId} {
        allow read: if isSignedIn();
        allow write: if isAdmin();
      }
    }
  }
}